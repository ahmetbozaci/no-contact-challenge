# App
NODE_ENV=production
PORT=3000
APP_URL=https://your-domain.com
TRUST_PROXY=true
MAX_BODY_BYTES=262144

# Admin
ADMIN_PASSWORD=replace-with-a-long-random-admin-password
FAIL_ON_CONFIG_WARNING=false

# Storage: json for local testing, postgres for production
STORAGE_DRIVER=postgres
DATABASE_URL=postgres://user:password@host:5432/no_contact
PGSSLMODE=require

# Email: dev for local testing, resend for production
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=No Contact Challenge <hello@your-domain.com>

# Optional backup helpers
BACKUP_DIR=./backups
