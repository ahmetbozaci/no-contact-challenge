# Render + Supabase + Resend production example
# Copy these keys into Render Dashboard > Environment.
# Do NOT commit real passwords or API keys.

NODE_ENV=production
PORT=3000
TRUST_PROXY=true
MAX_BODY_BYTES=262144

# Replace after first Render deploy, or with your custom domain.
APP_URL=https://your-render-service-name.onrender.com

# Use a long random value. Example generator:
# openssl rand -base64 32
ADMIN_PASSWORD=replace-with-a-long-random-admin-password

# Set true only if you want the app to refuse startup when required config is missing.
FAIL_ON_CONFIG_WARNING=true

# Supabase PostgreSQL
STORAGE_DRIVER=postgres
# Use Supabase Dashboard > Project Settings > Database > Connection string.
# Recommended for Render: Transaction pooler URI with ?pgbouncer=true when available.
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DATABASE_PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true
PGSSLMODE=require

# Resend email
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=No Contact Challenge <hello@your-verified-domain.com>

# Backup helpers
BACKUP_DIR=./backups
